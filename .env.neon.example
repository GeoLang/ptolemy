NEON_DATABASE_URL=postgres://ptolemy:YOUR_PASSWORD@ep-cool-name-123456.us-east-2.aws.neon.tech/ptolemy?sslmode=require

# JWT secret for Ptolemy API auth
PTOLEMY_JWT_SECRET=change-me-in-production
